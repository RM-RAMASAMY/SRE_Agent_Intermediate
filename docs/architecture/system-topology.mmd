%% Portrait / Word-friendly: stacked tiers inside one wrapper subgraph (TB).
%% Detailed MCP wiring: see mcp-integration.mmd. Original twin microservices
%% are summarized as one node here to avoid a wide gateway fan-out.

graph TB
    subgraph Topology[" "]
        direction TB

        subgraph Platform["platform + backend + sre_agent"]
            direction TB
            UI["dashboard"]
            API["sre_agent runtime"]
            STORES[("PostgreSQL · Redis · Qdrant")]
            UI -->|requests| API
            API -->|persist / state / vector memory| STORES
        end

        subgraph Edge["edge_mcp_servers"]
            direction TB
            MCPS["Kubernetes MCP<br/>Prometheus MCP<br/>Loki MCP<br/>GitHub MCP<br/>Runbooks MCP"]
        end

        subgraph Target["Target_Client"]
            direction TB
            CP["chaos-panel"]
            LG["load-generator"]
            GW["api-gateway"]
            SVC["checkout-service<br/>inventory-service"]
            CP -->|controls| LG
            LG -->|traffic| GW
            GW -->|routes| SVC
        end
    end

    MCPS -->|"MCP tool results (HTTP/SSE)"| API

    style Target fill:#e1f5ff
    style Edge fill:#fff3e0
    style Platform fill:#f3e5f5